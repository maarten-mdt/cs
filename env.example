# =============================================================================
# Copy this file to .env and fill in the values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required for auth + later chunks)
# -----------------------------------------------------------------------------
# PostgreSQL connection string. From Railway: add PostgreSQL plugin, copy DATABASE_URL.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# Session (required for admin login)
# -----------------------------------------------------------------------------
# Random string, at least 32 characters. Generate: openssl rand -hex 32
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth — admin login (Chunk 2)
# -----------------------------------------------------------------------------
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only allow this email domain to sign in (e.g. mdttac.com)
ALLOWED_EMAIL_DOMAIN=mdttac.com
# Must match exactly what you set in Google Console → Authorized redirect URIs.
# Local dev: http://localhost:3000/auth/google/callback
# Production: https://YOUR-APP-URL/auth/google/callback
AUTH_CALLBACK_URL=

# -----------------------------------------------------------------------------
# URLs — for CORS and redirects
# -----------------------------------------------------------------------------
# Where the admin dashboard is served (local dev: http://localhost:5173)
FRONTEND_URL=http://localhost:5173
# Where the public home/chat is served (often same as backend in production)
PUBLIC_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Server (optional — Railway sets PORT automatically)
# -----------------------------------------------------------------------------
# PORT=3000

# -----------------------------------------------------------------------------
# Redis (for BullMQ job queue — later chunks)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://default:password@host:port

# -----------------------------------------------------------------------------
# Anthropic — AI chat (Chunk 4+)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Shopify — order lookup (Chunk 5+)
# -----------------------------------------------------------------------------
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=shpat_...

# -----------------------------------------------------------------------------
# Zendesk — help center sync + escalation (Chunk 6–7)
# -----------------------------------------------------------------------------
# Subdomain only, e.g. "mdt" for mdt.zendesk.com (not the full domain)
# ZENDESK_SUBDOMAIN=
# ZENDESK_EMAIL=
# ZENDESK_API_TOKEN=

# -----------------------------------------------------------------------------
# HubSpot (Chunk 8+)
# -----------------------------------------------------------------------------
# HUBSPOT_API_KEY=

# -----------------------------------------------------------------------------
# Optional — website crawler
# -----------------------------------------------------------------------------
# Custom User-Agent to whitelist in Cloudflare WAF so crawler is not blocked
# CRAWLER_USER_AGENT=MDT-Crawler-your-secret-token
