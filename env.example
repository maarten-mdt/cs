# Required
ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: better answers via semantic search (add OPENAI_API_KEY for embeddings)
# OPENAI_API_KEY=sk-...

# Google Drive (for folder source)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com",...}
# Share the folder with client_email and paste the full JSON here.

# Shopify (for product/order lookup)
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...

# Zendesk (for escalation)
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_EMAIL=admin@mdttac.com
ZENDESK_API_TOKEN=...
